import { createClient } from '@supabase/supabase-js';

// Conectamos con tu base de datos usando las llaves que guardaste
const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
);

export default async function PropertiesPage() {
  // Pedimos las casas a la base de datos
  const { data: properties } = await supabase.from('properties').select('*');

  return (
    <div className="min-h-screen bg-gray-100 p-8">
      <h1 className="text-3xl font-bold mb-8 text-gray-800">🏠 Propiedades Disponibles</h1>
      
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {properties?.map((casa) => (
          <div key={casa.id} className="bg-white rounded-lg shadow-md overflow-hidden border border-gray-200">
            <div className="p-6">
              <h2 className="text-xl font-semibold mb-2 text-blue-600">{casa.titulo}</h2>
              <p className="text-gray-600 mb-4">{casa.descripcion}</p>
              <div className="flex justify-between items-center">
                <span className="text-2xl font-bold text-gray-900">
                  {new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(casa.precio)}
                </span>
                <span className="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded">
                  {casa.tipo.toUpperCase()}
                </span>
              </div>
              <p className="mt-4 text-sm text-gray-500">📍 {casa.direccion}</p>
            </div>
          </div>
        ))}
      </div>

      {(!properties || properties.length === 0) && (
        <p className="text-center text-gray-500 mt-10">No hay casas publicadas todavía.</p>
      )}
    </div>
  );
}
